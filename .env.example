# Copy to .env on the server and fill in values
# cp .env.example .env

DOCKERHUB_USERNAME=sanketsultan
DOMAIN=leetnode.io

# ── Feedback email (via Resend) ───────────────────────────────────────────────
# 1. Sign up at resend.com (free — 3000 emails/month)
# 2. Add leetnode.io as a sending domain → it gives you DNS records to add in Cloudflare
# 3. Copy the API key here
# 4. FEEDBACK_TO is where you receive the feedback (your personal email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FEEDBACK_TO=your-personal-email@gmail.com
